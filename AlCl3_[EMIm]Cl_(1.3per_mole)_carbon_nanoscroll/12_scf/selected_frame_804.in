&CONTROL
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix='ns',
    nstep=2000,
    pseudo_dir = '/home/elmer.barquero/carbon_nn/pseudo',
    outdir= '.',
    max_seconds=86000
/
&SYSTEM
    ntyp = 2
    nat = 5
   ibrav            = 0
   occupations='smearing', smearing='mp', degauss=0.02,
   vdw_corr='dft-d3'

/
&ELECTRONS
!   diagonalization  = 'cg'
   mixing_mode      = 'local-TF'
   mixing_beta      = 0.2
!   mixing_ndim      = 8
   conv_thr         = 1.0D-4
   electron_maxstep = 500
/

ATOMIC_SPECIES
Al 26.9815385 Al.pbe-n-kjpaw_psl.1.0.0.UPF
Cl 35.45 Cl.pbe-n-kjpaw_psl.1.0.0.UPF

K_POINTS gamma

